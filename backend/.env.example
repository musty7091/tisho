# ==================== MongoDB ====================
# Yerel MongoDB:
MONGODB_URI=mongodb://localhost:27017/tasarim-platform
# veya MongoDB Atlas (bulut):
# MONGODB_URI=mongodb+srv://kullanici:sifre@cluster.mongodb.net/tasarim-platform

# ==================== Sunucu ====================
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ==================== JWT (Kimlik Doğrulama) ====================
# ÖNEMLİ: Production'da bunları uzun rastgele değerlerle değiştirin
JWT_SECRET=bu-degeri-mutlaka-degistirin-uzun-rastgele-bir-deger
JWT_REFRESH_SECRET=baska-bir-uzun-rastgele-deger

# ==================== Email (Sipariş Bildirimleri) ====================
# Gmail için: hesap ayarlarından "Uygulama Şifresi" oluşturun
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=email-adresiniz@gmail.com
EMAIL_PASSWORD=gmail-uygulama-sifreniz
